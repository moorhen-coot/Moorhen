getglm() {
    cdcheckout
    if [ -r glm-$glm_release ]; then
        echo "Using existing glm"
    else
        echo "Downloading glm"
        curl -fL https://github.com/g-truc/glm/archive/refs/tags/$glm_release.tar.gz -o glm-$glm_release.tar.gz &&\
        echo &&\
        echo "Unpacking glm-$glm_release" &&\
        tar xf glm-$glm_release.tar.gz &&\
        cd ${MOORHEN_SOURCE_DIR} &&\
        echo "Linking glm headers" &&\
        mkdir -p include &&\
        cd include &&\
        rm -f glm &&\
        ln -s ../checkout/glm-$glm_release/glm glm || fail "Failed to download, unpack and link glm"
    fi
    echo
}

