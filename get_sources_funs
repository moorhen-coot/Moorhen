getcoot() {
    cdcheckout
    if [ -r coot-1.0 ]; then
        if [ "x$(git -C coot-1.0 rev-parse --short=10 main)" = "x$coot_commit" ];then
            echo "Using existing coot-1.0"
        else
            echo "Checking-out existent coot-1.0 to a different version ($(git -C coot-1.0 rev-parse --short=10 main) -> $coot_commit)"
            git -C coot-1.0 fetch &&\
            git -C coot-1.0 checkout $coot_commit &&\
            echo Using checked-out coot-1.0 || fail "Failed to checkout coot-1.0"
        fi
    else
        echo "Downloading coot-1.0..."
        git clone --branch main https://github.com/pemsley/coot.git coot-1.0 &&\
        git -C coot-1.0 fetch origin &&\
        git -C coot-1.0 checkout $coot_commit || fail "Failed to clone and checkout coot-1.0"
    fi
    echo
}

