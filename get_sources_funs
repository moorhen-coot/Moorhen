#!/bin/sh

if [ "x$MOORHEN_SOURCE_DIR" = "x" ]; then
    if command -v greadlink > /dev/null 2>&1; then
        MOORHEN_SOURCE_DIR=`dirname -- "$( greadlink -f -- "$0"; )"`
    else
        MOORHEN_SOURCE_DIR=`dirname -- "$( readlink -f -- "$0"; )"`
    fi
else
    echo "Using MOORHEN_SOURCE_DIR from environment: $MOORHEN_SOURCE_DIR"
fi

. ${MOORHEN_SOURCE_DIR}/VERSIONS

fail() {
    echo $1
    exit 1
}

cdcheckout() {
    mkdir -p ${MOORHEN_SOURCE_DIR}/checkout &&\
    cd ${MOORHEN_SOURCE_DIR}/checkout || fail "Failed to cd to checkout directory"
}

geteigen() {
    cdcheckout
    if [ -r eigen-$libeigen_release ]; then
        echo "Using existing LibEigen"
    else
        echo "Checking out LibEigen"
        curl -fL https://gitlab.com/libeigen/eigen/-/archive/$libeigen_release/eigen-$libeigen_release.tar.gz -o eigen-$libeigen_release.tar.gz &&\
        tar xf eigen-$libeigen_release.tar.gz || fail "Failed to download and unpack LibEigen"
    fi
    echo
}

getlibccp4() {
    cdcheckout
    if [ -r libccp4-$libccp4_release ]; then
        echo "Using existing libccp4"
    else
        echo "Checking out libccp4"
        curl -fL https://ftp.ccp4.ac.uk/opensource/libccp4-$libccp4_release.tar.gz -o libccp4-$libccp4_release.tar.gz &&\
        echo &&\
        echo "Unpacking libccp4 source" &&\
        tar xf libccp4-$libccp4_release.tar.gz &&\
        ln -s libccp4-$libccp4_release libccp4 &&\
        echo &&\
        echo "Patching libccp4 for Emscripten" &&\
        patch -p0 < ../patches/ccp4-emscripten.patch &&\
        cd .. || fail "Failed to download, unpack and patch libccp4"
    fi
    echo
}

getclipper() {
    cdcheckout
    if [ -r clipper ]; then
        echo "Using existing clipper"
    else
        echo "Checking out clipper (gemmi branch)"
        git clone -b gemmi https://ccp4forge.rc-harwell.ac.uk/ccp4/clipper.git || fail "Failed to clone clipper"
        echo
    fi
    echo
}

getssm() {
