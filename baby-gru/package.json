{
    "name": "moorhen",
    "version": "1.0.0-alpha.3",
    "private": false,
    "typesVersions": {
        "*": {
            "vite-plugin": [
                "scripts/VitePlugin.d.ts"
            ],
            "types/*": [
                "types/*"
            ]
        }
    },
    "exports": {
        "./react-lib": {
            "types": "./types/src/moorhen.d.ts",
            "default": "./moorhen-react-lib.js"
        },
        "./web-component": {
            "types": "./types/src/WebComponent/entry.d.ts",
            "default": "./moorhen.js"
        },
        "./vite-plugin": {
            "types": "./scripts/VitePlugin.d.ts",
            "default": "./scripts/VitePlugin.mjs"
        },
        "./web-component/utils": {
            "types": "./types/src/WebComponent/utils/entry.d.ts",
            "default": "./MoorhenWebComponentUtils.js"
        },
        "./types/*": {
            "types": "./types/*",
            "default": "./types/*"
        }
    },
    "homepage": "./",
    "author": "Paul Emsley, Filomeno Sanchez Rodriguez, Martin Noble, Jordan Dialpuri, Jakub Smulski, Lucrezia Catapano, Paul Bond, Clément Dégut, Stuart McNicholas",
    "description": "Moorhen molecular graphics",
    "license": "BSD-3-Clause",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/moorhen-coot/Moorhen.git"
    },
    "bugs": {
        "url": "https://github.com/moorhen-coot/Moorhen/issues"
    },
    "keywords": [
        "molecular graphics",
        "moorhen",
        "webcoot",
        "ccp4",
        "interactive model building"
    ],
    "scripts": {
        "transpile-graphql-codegen": "if ! test -r src/utils/__graphql__/gql.ts; then  npx graphql-codegen; fi",
        "transpile-protobuf": "npx pbjs -t static-module -w es6 -o ./src/protobuf/MoorhenSession.js ./src/protobuf/MoorhenSession.proto",
        "create-version": "npx genversion -e -p ./package.json -d -s ./src/version.js",
        "transpile-ts-worker": "npx tsc --project tsconfig.worker.json && sed -i.bak '/export {}/d' public/MoorhenAssets/wasm/CootWorker.js && rm public/MoorhenAssets/wasm/CootWorker.js.bak",
        "transpile-ts-worker-jest": "npm run transpile-ts-worker",
        "prestart": "npm run create-version && npm run transpile-ts-worker && npm run transpile-protobuf && npm run transpile-graphql-codegen",
        "start": "vite --config vite.config.mts",
        "start:preview": "npm run build-release-dev && echo 'Moorhen dist preview is running at http://localhost:3000/preview.dist.html' && python3 SimpleCrossOriginServer.py 3000",
        "start:webcomponent": "vite --config vite.WebC.config.mts",
        "prebuild": "npm run create-version && npm run transpile-ts-worker && npm run transpile-protobuf && npm run transpile-graphql-codegen",
        "build-vite": "vite build",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "setup-gemmi-dist": "mkdir -p dist/gemmi && cp public/MoorhenAssets/wasm/gemmi.js dist/gemmi/ && cp public/MoorhenAssets/wasm/gemmi.wasm dist/gemmi/ && cp src/types/gemmi-standalone.d.ts dist/gemmi/index.d.ts && echo 'module.exports = require(\"./gemmi.js\");' > dist/gemmi/index.js",
        "emit-declarations": "npx tsc  --emitDeclarationOnly; npx tsc-alias; sed -i.bak 's|import(\"\\.\\./|import(\"./src/|g' dist/types/moorhen.d.ts",
        "build-webcomponent": "webpack --config webpack.webcomponent.config.js --mode production --devtool source-map",
        "build-webcomponent-dev": "webpack --config webpack.webcomponent.config.js --mode development --devtool inline-source-map",
        "build-utils": "webpack --config webpack.utils.config.js --mode production ",
        "build-react": "webpack --config webpack.react.config.js --mode production --devtool source-map",
        "build-react-dev": "webpack --config webpack.react.config.js --mode development --devtool inline-source-map",
        "build-release": "rm -rf dist/* && npm run prebuild && concurrently \"npm run build-webcomponent\"  \"npm run build-react\" \"npm run build-utils\" && npm run emit-declarations",
        "build-release-dev": "rm -rf dist/* && npm run prebuild && concurrently \"npm run build-webcomponent-dev\"  \"npm run build-react-dev\" \"npm run build-utils\" && npm run emit-declarations",
        "build-and-pack": "npm run build-release && cd dist && npm pack && cd ..",
        "build-and-pack-dev": "npm run build-release-dev && cd dist && npm pack && cd ..",
        "build-and-pack-versioned": "node scripts/pack-versioned.mjs",
        "create-docs": "npm run create-version && npx jsdoc -c jsdoc.json ../README.md && mkdir -p docs/wasm_src_frontend && cp -a ../wasm_src_frontend/baby_gru.png docs/wasm_src_frontend",
        "test-api": "npm run create-version && npm run transpile-protobuf && npm run transpile-graphql-codegen && npx tsc && npm run transpile-ts-worker && env MOORHEN_TEST_PTHREAD_POOL_SIZE=${MOORHEN_TEST_PTHREAD_POOL_SIZE:-1} node --trace-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --selectProjects api-utils --runInBand --detectOpenHandles --forceExit --expand --reporters=jest-silent-reporter --reporters=summary",
        "test": "npm run test-api && npm run test-react",
        "test-react": "npm run create-version && npm run transpile-protobuf && npm run transpile-graphql-codegen && npx tsc && node --trace-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --detectOpenHandles --forceExit --testPathIgnorePatterns=MoorhenContainer.test.jsx --testPathIgnorePatterns=MoorhenLigandMenu.test.jsx --testPathIgnorePatterns=MoorhenEditMenu.test.jsx --selectProjects react-components",
        "debug-hmr": "DEBUG=vite:hmr,vite:react-refresh npm run start"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "dependencies": {
        "@apollo/client": "^3.13.8",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@graphql-typed-document-node/core": "^3.2.0",       
        "biojs-io-fasta": "^0.1.17",
        "chart.js": "^4.5.0",
        "chartjs-plugin-annotation": "^3.1.0",
        "d3": "^7.9.0",
        "fuse.js": "^7.1.0",
        "gl-matrix": "^3.4.4",
        "graphql": "^16.11.0",
        "html-react-parser": "^5.2.6",
        "jszip": "^3.10.1",
        "localforage": "^1.10.0",
        "notistack": "^3.0.2",
        "npm": "^11.15.0",
        "pako": "^2.1.0",
        "prismjs": "^1.30.0",
        "protobufjs": "^7.5.4",
        "react-colorful": "^5.6.1",
        "react-dropzone": "^14.3.8",
        "react-hotkeys": "^2.0.0",
        "react-simple-code-editor": "^0.14.1",
        "styled-components": "^6.1.19",
        "util": "^0.12.5",
        "uuid": "^13.0.0",
        "web-vitals": "^5.1.0",
        "webpack-merge": "^6.0.1",
        "y-websocket": "^3.0.0",
        "yjs": "^13.6.27"
    },
    "devDependencies": {
        "@swc/react-compiler": "^1.15.32",
        "@babel/core": "^7.28.4",
        "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
        "@babel/plugin-transform-object-rest-spread": "^7.28.4",
        "@babel/preset-env": "^7.28.3",
        "@babel/preset-react": "^7.27.1",
        "@eslint/css": "^1.2.0",
        "@eslint/js": "^9.39.0",
        "@graphql-codegen/cli": "^6.0.0",
        "@graphql-codegen/client-preset": "^5.1.0",
        "@reduxjs/toolkit": "^2.9.0",
        "@svgr/webpack": "^8.1.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/jest": "^30.0.0",
        "@types/jszip": "^3.4.0",
        "@types/node": "^24.7.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.1",
        "@typescript-eslint/eslint-plugin": "^8.59.1",
        "@typescript-eslint/parser": "^8.59.1",
        "@vitejs/plugin-react": "^5.0.4",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "babel-loader": "^10.0.0",
        "babel-plugin-react-compiler": "^19.1.0-rc.2",
        "concurrently": "^9.2.1",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^7.1.2",
        "docdash": "^2.0.2",
        "dts-bundle-generator": "^9.5.1",
        "ts-jest": "^29.4.5",
        "esbuild": "0.28.0",
        "eslint": "^9.39.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-perf": "^3.3.3",
        "eslint-plugin-react-refresh": "^0.4.23",
        "eslint-plugin-react-you-might-not-need-an-effect": "^0.5.6",
        "file-loader": "^6.2.0",
        "genversion": "^3.2.0",
        "globals": "^16.4.0",
        "jest-silent-reporter": "^0.6.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "jsdoc": "^4.0.5",
        "jsdoc-babel": "^0.5.0",
        "mini-css-extract-plugin": "^2.9.4",
        "node-fetch": "^2.7.0",
        "node-gzip": "^1.1.2",
        "nodemon": "^3.1.10",
        "protobufjs-cli": "^1.1.3",
        "react": "^19.2.0",
        "react-compiler-webpack": "^1.0.0",
        "react-dom": "^19.2.0",
        "react-redux": "^9.2.0",
        "rollup": "^4.52.5",
        "sass": "^1.93.2",
        "sass-loader": "^16.0.5",
        "style-loader": "^4.0.0",
        "svgo": "^4.0.0",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.17",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-checker": "^0.11.0",
        "vite-plugin-cross-origin-isolation": "^0.1.6",
        "vite-plugin-svgr": "^4.5.0",
        "vite-plugin-top-level-await": "^1.6.0",
        "vite-plugin-wasm": "^3.5.0",
        "wait-on": "^9.0.1",
        "webpack": "^5.106.2",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.2",
        "worker-loader": "^3.0.8"
    }
}
